{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_doc": "Aevum orchestrator settings. Deny list (mechanical safety net), hooks wired (commit-policy + forbidden-patterns + worktree-jail + claude-dir-write + plan-frontmatter + session-reminders + session-hygiene-warn), templates under .claude/templates/. Personal overrides go in .claude/settings.local.json (gitignored). The Bash allow list below ships with a Node/pnpm default near the bottom; add or remove tooling entries to match your stack (see docs/swap-points.md). See CLAUDE.md and .claude/rules/00-index.md.",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Edit(.claude/agents/*.md)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(git mv:*)",
      "Bash(git rm:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(date:*)",
      "Bash(env:*)",
      "Bash(pwd:*)",
      "Bash(cd:*)",
      "Bash(test:*)",
      "Bash([ *)",
      "Bash(bash .claude/scripts/cleanup-stale-block.sh*)",
      "Bash(.claude/scripts/cleanup-stale-block.sh*)",
      "Bash(bash .claude/scripts/orchestrate-block-loop.sh*)",
      "Bash(.claude/scripts/orchestrate-block-loop.sh*)",
      "Bash(bash scripts/capture-baseline.sh*)",
      "Bash(scripts/capture-baseline.sh*)",
      "Bash(python3 scripts/block-preflight.py*)",
      "Bash(python3 scripts/check-stale-gate-verdicts.py*)",
      "Bash(python3 scripts/check-fix-loop-budget.py*)",
      "Bash(python3 scripts/baseline-diff.py*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push origin*)",
      "Bash(git push --all*)",
      "Bash(git push --tags*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git remote add*)",
      "Bash(git remote set-url*)",
      "Bash(git reset --hard*)",
      "Bash(git reset -*-hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(git rebase -i*)",
      "Bash(git rebase --interactive*)",
      "Bash(git commit --amend*)",
      "Bash(git commit -*-amend*)",
      "Bash(git checkout --orphan*)",
      "Bash(git checkout --detach*)",
      "Bash(git tag -d*)",
      "Bash(git tag --delete*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)",
      "Bash(git update-ref*)",
      "Bash(git reflog expire*)",
      "Bash(git gc --prune*)",
      "Bash(git add -A*)",
      "Bash(git add --all*)",
      "Bash(git add .)",
      "Bash(rm -rf*)",
      "Bash(rm -r *)",
      "Bash(rm -f /*)",
      "Bash(rm /*)",
      "Bash(find * -delete*)",
      "Bash(find * -exec rm*)",
      "Bash(sudo*)",
      "Bash(su -*)",
      "Bash(chmod 777*)",
      "Bash(chmod -R 777*)",
      "Bash(chown*)",
      "Bash(dd if=*)",
      "Bash(dd of=*)",
      "Bash(mkfs*)",
      "Bash(mount*)",
      "Bash(umount*)",
      "Bash(kill -9*)",
      "Bash(killall*)",
      "Bash(pkill*)",
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)",
      "Bash(yarn publish*)",
      "Bash(twine upload*)",
      "Bash(uv publish*)",
      "Bash(cargo publish*)",
      "Bash(docker push*)",
      "Bash(docker login*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/credentials)",
      "Write(**/credentials.*)",
      "Write(**/secrets.*)",
      "Write(**/*.key)",
      "Write(**/*.pem)",
      "Write(**/*.p12)",
      "Write(**/*.pfx)",
      "Write(**/id_rsa)",
      "Write(**/id_ed25519)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/credentials)",
      "Edit(**/credentials.*)",
      "Edit(**/secrets.*)",
      "Edit(**/*.key)",
      "Edit(**/*.pem)",
      "Edit(**/*.p12)",
      "Edit(**/*.pfx)",
      "Edit(**/id_rsa)",
      "Edit(**/id_ed25519)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/*.key)",
      "Read(**/*.pem)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/commit-policy.sh\"" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/forbidden-patterns.sh\"" }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/worker-worktree-jail.sh\"" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/claude-dir-write.sh\"" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/forbidden-patterns-live.sh\"" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/plan-frontmatter.sh\"" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-reminders.sh\"" }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-hygiene-warn.sh\"" }
        ]
      }
    ]
  },
  "mcpServers": {}
}
