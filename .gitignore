# =============================================================================
# Aevum .gitignore
# =============================================================================
# The harness itself is configuration. Runtime artefacts live under logs/.
# Stack-specific build caches (node_modules, target/, .venv/, etc.) are
# project-side and listed below as a starter set; remove or extend per
# the project's actual stack.
# =============================================================================

# ---- secrets ----
.env
.env.*
!.env.example
!.env.local.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
credentials*

# ---- harness runtime (never committed) ----
/logs/
/.claude/worktrees/
/.claude/settings.local.json
/.claude/state.local.yaml

# ---- common dev junk ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ---- common build / cache directories (extend per stack) ----
# Node
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.venv/
venv/
ENV/

# Rust
target/
**/*.rs.bk
Cargo.lock.bak

# Go
*.test
*.prof

# Deploy artefacts
.vercel
.netlify
